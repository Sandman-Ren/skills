{
  "name": "_security",
  "description": "Deny rules for destructive operations and sensitive file access. Always included.",
  "allow": [],
  "ask": [],
  "deny": [
    "Bash(rm -rf *)",
    "Bash(rm -r *)",
    "Bash(* sudo *)",
    "Bash(sudo *)",
    "Bash(su *)",
    "Bash(runas *)",
    "Bash(dd *)",
    "Bash(mkfs *)",
    "Bash(fdisk *)",
    "Bash(format *)",
    "Bash(chmod 777 *)",
    "Bash(chmod -R 777 *)",
    "Bash(git push --force *)",
    "Bash(git push -f *)",
    "Bash(git push --force-with-lease *)",
    "Bash(git reset --hard *)",
    "Bash(git clean -f *)",
    "Bash(git clean -fd *)",
    "Bash(git clean -fx *)",

    "Read(./**/.env)",
    "Read(./**/.env.local)",
    "Read(./**/.env.*.local)",
    "Read(./**/secrets/**)",
    "Read(~/.ssh/**)",
    "Read(~/.aws/**)",
    "Read(~/.kube/**)",
    "Read(~/.config/gcloud/**)",
    "Read(~/.azure/**)",
    "Read(./**/*credentials*)",
    "Read(./**/*.pem)",
    "Read(./**/*.key)",
    "Read(./**/*.p12)",
    "Read(./**/*.pfx)",
    "Read(./**/.htpasswd)",
    "Read(~/.netrc)"
  ]
}
