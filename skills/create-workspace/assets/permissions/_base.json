{
  "name": "_base",
  "description": "Core read-only tools, git read commands, worktree management, and general utilities. Always included.",
  "allow": [
    "Read",
    "Glob",
    "Grep",
    "WebSearch",

    "Bash(git status)",
    "Bash(git status *)",
    "Bash(git diff)",
    "Bash(git diff *)",
    "Bash(git log)",
    "Bash(git log *)",
    "Bash(git show)",
    "Bash(git show *)",
    "Bash(git branch)",
    "Bash(git branch *)",
    "Bash(git stash list)",
    "Bash(git worktree list)",
    "Bash(git worktree add *)",
    "Bash(git worktree remove *)",
    "Bash(git worktree prune)",
    "Bash(git ls-files *)",
    "Bash(git ls-tree *)",
    "Bash(git rev-parse *)",
    "Bash(git remote *)",
    "Bash(git describe *)",
    "Bash(git shortlog *)",
    "Bash(git blame *)",
    "Bash(git tag)",
    "Bash(git tag -l *)",

    "Bash(ls)",
    "Bash(ls *)",
    "Bash(tree *)",
    "Bash(pwd)",
    "Bash(wc *)",
    "Bash(which *)",
    "Bash(where *)",
    "Bash(whoami)",
    "Bash(hostname)",
    "Bash(make *)",
    "Bash(* --version)",
    "Bash(* --help)"
  ],
  "ask": [
    "Bash(git add *)",
    "Bash(git commit *)",
    "Bash(git push *)",
    "Bash(git pull *)",
    "Bash(git merge *)",
    "Bash(git rebase *)",
    "Bash(git checkout *)",
    "Bash(git switch *)",
    "Bash(git stash *)",
    "Bash(git cherry-pick *)",
    "Bash(git fetch *)",
    "Bash(git reset *)",
    "Bash(git tag *)"
  ],
  "deny": []
}
