{
  "name": "nodejs",
  "description": "Node.js ecosystem — npm, yarn, pnpm, bun for building, testing, linting, and dependency management.",
  "detect": ["package.json"],
  "allow": [
    "Bash(npm run *)",
    "Bash(npm test *)",
    "Bash(npm list *)",
    "Bash(npm ls *)",
    "Bash(npm outdated *)",
    "Bash(npm audit *)",
    "Bash(npm view *)",
    "Bash(npm info *)",
    "Bash(npm explain *)",
    "Bash(npm why *)",
    "Bash(npx prettier *)",
    "Bash(npx eslint *)",
    "Bash(npx tsc *)",
    "Bash(npx vitest *)",
    "Bash(npx jest *)",
    "Bash(yarn run *)",
    "Bash(yarn test *)",
    "Bash(yarn info *)",
    "Bash(yarn why *)",
    "Bash(pnpm run *)",
    "Bash(pnpm test *)",
    "Bash(pnpm list *)",
    "Bash(pnpm ls *)",
    "Bash(pnpm outdated *)",
    "Bash(pnpm why *)",
    "Bash(bun run *)",
    "Bash(bun test *)"
  ],
  "ask": [
    "Bash(npm install *)",
    "Bash(npm ci)",
    "Bash(npm ci *)",
    "Bash(npm uninstall *)",
    "Bash(yarn install *)",
    "Bash(yarn add *)",
    "Bash(yarn remove *)",
    "Bash(pnpm install *)",
    "Bash(pnpm add *)",
    "Bash(pnpm remove *)",
    "Bash(bun install *)",
    "Bash(bun add *)",
    "Bash(bun remove *)"
  ],
  "deny": []
}
