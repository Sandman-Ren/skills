{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_modules": ["_base", "_security"],
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(git worktree list)",
      "Bash(git worktree add *)",
      "Bash(git worktree remove *)",
      "Bash(git worktree prune)",
      "Bash(git ls-files *)",
      "Bash(git ls-tree *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git describe *)",
      "Bash(git shortlog *)",
      "Bash(git blame *)",
      "Bash(git tag)",
      "Bash(git tag -l *)",

      "Bash(ls)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(pwd)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(where *)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(make *)",
      "Bash(* --version)",
      "Bash(* --help)"
    ],

    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git stash *)",
      "Bash(git cherry-pick *)",
      "Bash(git fetch *)",
      "Bash(git reset *)",
      "Bash(git tag *)"
    ],

    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(* sudo *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(runas *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(format *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fx *)",

      "Read(./**/.env)",
      "Read(./**/.env.local)",
      "Read(./**/.env.*.local)",
      "Read(./**/secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.azure/**)",
      "Read(./**/*credentials*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./**/.htpasswd)",
      "Read(~/.netrc)"
    ]
  }
}
